OPENAI_API_KEY=
OPENAI_ORGANIZATION_ID=
OPENAI_PROJECT_ID=
OPENAI_BASE_URL=
OPENAI_MODEL_QUESTION=gpt-5.4-nano
OPENAI_MODEL_RUBRIC=gpt-5.4-nano
OPENAI_MODEL_EVAL=gpt-5.4-mini
OPENAI_MODEL_MCQ=gpt-5.4-nano
OPENAI_TEMPERATURE=0.0
OPENAI_MAX_OUTPUT_TOKENS_QUESTION=1200
OPENAI_MAX_OUTPUT_TOKENS_RUBRIC=300
OPENAI_MAX_OUTPUT_TOKENS_EVAL=700
OPENAI_MAX_OUTPUT_TOKENS_MCQ=1400
OPENAI_TIMEOUT_SECONDS=30.0
OPENAI_MAX_RETRIES=1
OPENAI_GENERATION_CHUNK_SIZE=10
OPENAI_TOPIC_BATCH_SIZE=4
LLM_CACHE_ENABLED=true
LLM_CACHE_BACKEND=redis
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_PREFIX=examecho:llm:
REDIS_CONNECT_RETRIES=3
REDIS_CONNECT_BACKOFF_SECONDS=0.5
REDIS_CONNECT_TIMEOUT_SECONDS=2.0
LLM_CACHE_PATH=.cache/llm_cache.sqlite3
LLM_CACHE_TTL_SECONDS=604800
WHISPER_MODEL_SIZE=base
STT_DEFAULT_MODEL=whisper
STT_VAD_ENABLED=false
MCQ_EVAL_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
MCQ_SIMILARITY_THRESHOLD=0.75
TTS_AUDIO_DIR=generated_audio
CORS_ORIGINS=["*"]
API_V1_PREFIX=/api/v1
